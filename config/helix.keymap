#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>


/ {
       keymap {
              compatible = "zmk,keymap";

              default_layer {
                     bindings = <
&kp ESC	&kp N1	&kp N2	&kp N3	&kp N4	&kp N5	&kp C	&kp C	&bt BT_SEL 1		&kp F9	&kp F8	&kp F7	&kp BACKSLASH	&kp O	&kp I	&kp U	&kp Y	&bt BT_SEL 2
&kp TAB	&kp Q	&kp W	&kp E	&kp R	&kp T	&kp LBKT	&kp RBKT	&bt BT_NXT	&bt BT_CLR	&kp F12	&kp F11	&kp F10	&kp N0	&kp N9	&kp N8	&kp N7	&kp N6	&bt BT_SEL 3
&kp CAPS	&kp A	&kp S	&kp D	&kp F	&kp G	&kp ENTER	&kp C	&kp UP	&kp C_PP	&kp F6	&kp F5	&kp F4	&kp SEMI	&kp L	&kp K	&kp J	&kp H	&kp ENTER
&kp LSHIFT	&kp Z	&kp X	&kp C	&kp V	&kp B	&kp DEL	&kp LEFT	&kp DOWN	&kp RIGHT	&kp F3	&kp F2	&kp F1	&kp APOS	&kp PERIOD	&kp COMMA	&kp M	&kp N	&kp RSHIFT
&kp LCTRL	&kp LWIN	&kp LALT	&kp SPACE	&kp SPACE	&kp SPACE	&kp BACKSPACE	&kp DEL	&kp C	&kp C_MUTE	&kp EQUAL	&kp MINUS	&kp SLASH	&kp BACKSLASH	&kp GRAVE	&kp SPACE	&kp SPACE	&kp ENTER	&kp BACKSPACE
                     >; 

                     sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
              };
       };
};

